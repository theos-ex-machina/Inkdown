# ─── Node / Vite ──────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local
.npm/
.pnpm-store/

# Lockfiles from package managers we don't use
yarn.lock
pnpm-lock.yaml

# ─── Tauri / Rust ─────────────────────────────────────────────────────────
src-tauri/target/
src-tauri/gen/
src-tauri/Cargo.lock.bak
**/*.rs.bk

# Tauri bundler output (installers, .app, .dmg, .deb, .AppImage, .msi, …)
src-tauri/target/release/bundle/

# Tauri / WiX intermediate
src-tauri/WixTools/

# ─── App data / vaults ────────────────────────────────────────────────────
# Local test vault(s) – user content, not source
notes-test/
notes/
vault/
*.inkdown-vault/

# Inkdown index sidecar produced inside any vault checked into the repo
.inkdown/

# ─── Logs / diagnostics ───────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS / editor cruft ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# JetBrains
.idea/

# VS Code – keep recommended extensions, ignore everything else
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json

# Cursor / Windsurf / agent scratch
.cursor/
.windsurfrules

# ─── Env / secrets ────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Misc ─────────────────────────────────────────────────────────────────
*.swp
*.swo
*.tmp
*.bak
*.orig
